{
  "name": "chrome-devtools-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Chrome DevTools — enables AI assistants to interact with Chrome browser via CDP",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "chrome-devtools-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "lint:fix": "eslint src --ext .ts --fix",
    "check": "npm run typecheck && npm run lint"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chrome-remote-interface": "^0.33.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.31.7",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chrome",
    "devtools",
    "cdp",
    "browser-automation",
    "ai"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/chrome-devtools/chrome-devtools-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/chrome-devtools/chrome-devtools-mcp/issues"
  },
  "homepage": "https://github.com/chrome-devtools/chrome-devtools-mcp#readme"
}
